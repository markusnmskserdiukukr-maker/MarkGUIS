-- Input
local function input(parent, ph)
    local t = Instance.new("TextBox")
    t.Size = UDim2.new(0,260,0,38)
    t.BackgroundColor3 = Color3.fromRGB(45,45,45)
    t.TextColor3 = Color3.new(1,1,1)
    t.PlaceholderText = ph
    t.Font = Enum.Font.Gotham
    t.TextSize = 14
    Instance.new("UICorner", t).CornerRadius = UDim.new(0,10)
    t.Parent = parent
    return t
end

local WalkBox = input(SettingsFrame,"WalkSpeed")
local JumpBox = input(SettingsFrame,"JumpHeight")
local HpBox = input(SettingsFrame,"Health")

local Apply = Instance.new("TextButton", SettingsFrame)
Apply.Size = UDim2.new(0,260,0,42)
Apply.Text = "Apply"
Apply.BackgroundColor3 = Color3.fromRGB(70,130,255)
Apply.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", Apply).CornerRadius = UDim.new(0,12)

Apply.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    local w = tonumber(WalkBox.Text)
    local j = tonumber(JumpBox.Text)
    local h = tonumber(HpBox.Text)

    if w then hum.WalkSpeed = w end
    if j then hum.JumpHeight = j end
    if h then hum.Health = h end
end)


-- Input creator
local function createInput(yPos, placeholder)
    local box = Instance.new("TextBox", Frame)
    box.Size = UDim2.new(0, 260, 0, 32)
    box.Position = UDim2.new(0.5, -130, 0, yPos)
    box.PlaceholderText = placeholder
    box.Text = ""
    box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    box.TextColor3 = Color3.fromRGB(255,255,255)
    box.Font = Enum.Font.Gotham
    box.TextSize = 14
    box.ClearTextOnFocus = false

    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke", box)
    stroke.Color = Color3.fromRGB(70,70,70)

    return box
end

-- Inputs
local WalkBox = createInput(55, "WalkSpeed")
local JumpBox = createInput(95, "JumpHeight")
local HpBox   = createInput(135, "Set Health")
local SpeedBox = createInput(175, "Fly Speed")

-- Button creator
local function createButton(text, yPos)
    local btn = Instance.new("TextButton", Frame)
    btn.Size = UDim2.new(0, 260, 0, 38)
    btn.Position = UDim2.new(0.5, -130, 0, yPos)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(70, 130, 255)
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 15

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(90,90,90)

    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(90, 150, 255)
    end)

    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(70, 130, 255)
    end)

    return btn
end

-- Buttons
local ApplyButton = createButton("Apply", 220)
local FlyButton = createButton("Fly OFF", 265)

-- Apply logic
ApplyButton.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    local walk = tonumber(WalkBox.Text)
    local jump = tonumber(JumpBox.Text)
    local hp   = tonumber(HpBox.Text)

    if walk then
        humanoid.WalkSpeed = walk
    end

    if jump then
        humanoid.UseJumpPower = false
        humanoid.JumpHeight = jump
    end

    if hp then
        humanoid.MaxHealth = hp
        humanoid.Health = hp
    end
end)

-- Fly system
local flying = false
local bodyVelocity
local flySpeed = 50
local flyConnection

local function startFly()
    local char = player.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bodyVelocity.Velocity = Vector3.new(0,0,0)
    bodyVelocity.Parent = hrp

    flying = true

    flyConnection = RunService.RenderStepped:Connect(function()
        if not flying then return end

        local cam = workspace.CurrentCamera
        local move = Vector3.new(0,0,0)

        local moving = false

        if UIS:IsKeyDown(Enum.KeyCode.W) then
            move += cam.CFrame.LookVector
            moving = true
        end
        if UIS:IsKeyDown(Enum.KeyCode.S) then
            move -= cam.CFrame.LookVector
            moving = true
        end
        if UIS:IsKeyDown(Enum.KeyCode.A) then
            move -= cam.CFrame.RightVector
            moving = true
        end
        if UIS:IsKeyDown(Enum.KeyCode.D) then
            move += cam.CFrame.RightVector
            moving = true
        end

        if UIS:IsKeyDown(Enum.KeyCode.Space) then
            move += Vector3.new(0,1,0)
            moving = true
        end

        if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
            move -= Vector3.new(0,1,0)
            moving = true
        end

        if moving then
            bodyVelocity.Velocity = move.Unit * flySpeed
        else
            bodyVelocity.Velocity = Vector3.new(0,0,0)
        end
    end)
end

local function stopFly()
    flying = false
    
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    
    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
end

-- Fly button
FlyButton.MouseButton1Click:Connect(function()
    if flying then
        stopFly()
        FlyButton.Text = "Fly OFF"
    else
        local value = tonumber(SpeedBox.Text)
        if value then
            flySpeed = value
        end
        
        startFly()
        FlyButton.Text = "Fly ON"
    end
end)

-- Drag
local dragging = false
local dragStart, startPos

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

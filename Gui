FlyButton.BackgroundColor3 = Color3.fromRGB(70,130,255)
FlyButton.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", FlyButton)

-- Fly logic
local flying = false
local bodyVelocity
local flySpeed = 50
local flyConn

local function startFly()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e9,1e9,1e9)
    bodyVelocity.Parent = hrp

    flying = true

    flyConn = RunService.RenderStepped:Connect(function()
        if not flying then return end

        local cam = workspace.CurrentCamera
        local move = Vector3.new(0,0,0)
        local moving = false

        if UIS:IsKeyDown(Enum.KeyCode.W) then move += cam.CFrame.LookVector moving = true end
        if UIS:IsKeyDown(Enum.KeyCode.S) then move -= cam.CFrame.LookVector moving = true end
        if UIS:IsKeyDown(Enum.KeyCode.A) then move -= cam.CFrame.RightVector moving = true end
        if UIS:IsKeyDown(Enum.KeyCode.D) then move += cam.CFrame.RightVector moving = true end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0,1,0) moving = true end
        if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0,1,0) moving = true end

        if moving then
            bodyVelocity.Velocity = move.Unit * flySpeed
        else
            bodyVelocity.Velocity = Vector3.new(0,0,0)
        end
    end)
end

local function stopFly()
    flying = false
    if flyConn then flyConn:Disconnect() end
    if bodyVelocity then bodyVelocity:Destroy() end
end

FlyButton.MouseButton1Click:Connect(function()
    local val = tonumber(SpeedBox.Text)
    if val then flySpeed = val end

    if flying then
        stopFly()
        FlyButton.Text = "Fly OFF"
    else
        startFly()
        FlyButton.Text = "Fly ON"
    end
end)


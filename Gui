-- Input creator
local function createInput(parent, y, placeholder)
    local box = Instance.new("TextBox", parent)
    box.Size = UDim2.new(0, 260, 0, 32)
    box.Position = UDim2.new(0.5, -130, 0, y)
    box.PlaceholderText = placeholder
    box.BackgroundColor3 = Color3.fromRGB(40,40,40)
    box.TextColor3 = Color3.new(1,1,1)
    box.ClearTextOnFocus = false
    Instance.new("UICorner", box).CornerRadius = UDim.new(0,8)
    return box
end

-- SETTINGS TAB
local WalkBox = createInput(SettingsFrame, 10, "WalkSpeed")
local JumpBox = createInput(SettingsFrame, 60, "JumpHeight")
local HpBox   = createInput(SettingsFrame, 110, "Health")

local ApplyBtn = Instance.new("TextButton", SettingsFrame)
ApplyBtn.Size = UDim2.new(0,260,0,40)
ApplyBtn.Position = UDim2.new(0.5,-130,0,160)
ApplyBtn.Text = "Apply"
ApplyBtn.BackgroundColor3 = Color3.fromRGB(70,130,255)
ApplyBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", ApplyBtn)

ApplyBtn.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    local walk = tonumber(WalkBox.Text)
    local jump = tonumber(JumpBox.Text)
    local hp = tonumber(HpBox.Text)

    if walk then hum.WalkSpeed = walk end
    if jump then
        hum.UseJumpPower = false
        hum.JumpHeight = jump
    end
    if hp then
        hum.MaxHealth = hp
        hum.Health = hp
    end
end)

-- FLY TAB
local SpeedBox = createInput(FlyFrame, 10, "Fly Speed")

local FlyButton = Instance.new("TextButton", FlyFrame)
